      "$PRIMARY$": "#0f3460",
      "$PRIMARY_TXT$": "#e9e9eb",
      "$BUTTON_BG$": "#e94560",
      "$INPUT_BG$": "#16213e",
      "$CHIP_BG$": "#16213e",
      "$CHAT_BUBBLE_USER$": "#e94560",
      "$CHAT_BUBBLE_AI$": "#1f2a48"
    }
  },
  "screens": {
    "home": {
      "title": "Ana Ekran",
      "style": { "backgroundColor": "$BG$", "justifyContent": "center" },
      "elements": [
        {
          "type": "image",
          "src": "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
          "style": { "width": "100%", "height": 200, "borderRadius": 24, "marginBottom": 20, "borderWidth": 2, "borderColor": "$BORDER$" }
        },
        {
          "type": "container",
          "style": { "backgroundColor": "$CARD_BG$", "borderRadius": 24, "padding": 25, "borderWidth": 2, "borderColor": "$BORDER$", "marginBottom": 30 },
          "children": [
            { "type": "text", "content": "CareerMate AI 🚀", "style": { "fontSize": 36, "fontWeight": "900", "color": "$TEXT$", "marginBottom": 15, "textAlign": "center" } },
            { "type": "text", "content": "Dinamik Tema (Dark/Light Mode) destekli, tamamen Server-Driven yapay zeka mentorun.", "style": { "fontSize": 16, "color": "$TEXT_MUTED$", "textAlign": "center" } }
          ]
        },
        {
          "id": "goToProfile",
          "type": "button",
          "content": "📝 Kariyer Profilini Çıkar",
          "action": { "type": "NAVIGATE", "target": "profile" },
          "style": { "backgroundColor": "$PRIMARY$", "padding": 20, "borderRadius": 16, "marginBottom": 15, "alignItems": "center" },
          "textStyle": { "color": "$PRIMARY_TXT$", "fontWeight": "900", "fontSize": 18 }
        },
        {
          "id": "goToCV",
          "type": "button",
          "content": "🎓 Europass ATS CV'ni Üret",
          "action": { "type": "NAVIGATE", "target": "cv_form" },
          "style": { "backgroundColor": "$PRIMARY$", "padding": 20, "borderRadius": 16, "marginBottom": 15, "alignItems": "center" },
          "textStyle": { "color": "$PRIMARY_TXT$", "fontWeight": "900", "fontSize": 18 }
        },
        {
          "id": "goToJobs",
          "type": "button",
          "content": "✨ AI ile İş İlanlarını Bul",
          "action": { "type": "FIND_JOBS_ACTION" },
          "style": { "backgroundColor": "$BUTTON_BG$", "padding": 20, "borderRadius": 16, "marginBottom": 15, "alignItems": "center" },
          "textStyle": { "color": "#fff", "fontWeight": "900", "fontSize": 18 }
        },
        {
          "id": "themeToggle",
          "type": "button",
          "content": "🌗 Gece/Gündüz Modu",
          "action": { "type": "TOGGLE_THEME" },
          "style": { "backgroundColor": "$CHIP_BG$", "padding": 15, "borderRadius": 16, "alignItems": "center", "marginBottom": 15, "borderWidth": 2, "borderColor": "$BORDER$" },
          "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 16 }
        }
      ]
    },
    "profile": {
      "title": "Profil Ekranı",
      "style": { "backgroundColor": "$BG$" },
      "elements": [
        {
          "type": "container",
          "style": { "flexDirection": "row", "justifyContent": "space-between", "marginBottom": 15, "marginTop": 10 },
          "children": [
            { "type": "text", "content": "PROFİL TAMAMLAMA: SEVİYE 1", "style": { "fontSize": 10, "fontWeight": "bold", "color": "$TEXT_MUTED$", "letterSpacing": 1.5 } },
            { "type": "text", "content": "XP 250/1000", "style": { "fontSize": 12, "fontWeight": "bold", "fontStyle": "italic", "color": "$PRIMARY$" } }
          ]
        },
        {
          "type": "text",
          "content": "Seni Tanıyalım",
          "style": { "fontSize": 44, "fontWeight": "900", "color": "$TEXT$", "marginBottom": 10, "textAlign": "center" }
        },
        {
          "type": "text",
          "content": "Gelecekteki benliğini inşa etmeye hazır mısın? Kariyer yolculuğun burada başlıyor.",
          "style": { "fontSize": 16, "color": "$TEXT_MUTED$", "marginBottom": 40, "textAlign": "center", "paddingHorizontal": 20 }
        },
        {
          "type": "container",
          "style": { "backgroundColor": "$CARD_BG$", "borderRadius": 24, "padding": 25, "marginBottom": 40, "borderWidth": 2, "borderColor": "$BORDER$" },
          "children": [
            { "type": "container", "style": {"flexDirection": "row", "marginBottom": 15, "alignItems": "center"}, "children": [
               { "type": "text", "content": "🎮", "style": { "fontSize": 24, "marginRight": 10, "backgroundColor": "$CHIP_BG$", "padding": 8, "borderRadius": 12, "overflow": "hidden" } },
               { "type": "container", "style": {}, "children": [
                 { "type": "text", "content": "Hedefini Tanımla", "style": { "fontSize": 20, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 2 } },
                 { "type": "text", "content": "Hayalindeki kariyer hedefini buraya yaz...", "style": { "fontSize": 13, "color": "$TEXT_MUTED$" } }
               ]}
            ]},
            { "type": "textInput", "id": "career_goal", "placeholder": "Örn: Sürdürülebilir şehirler...", "multiline": true, "style": { "height": 120, "backgroundColor": "$INPUT_BG$", "borderRadius": 16, "padding": 20, "fontSize": 16, "borderWidth": 2, "borderColor": "$BORDER$", "textAlignVertical": "top", "color": "$TEXT$" } }
          ]
        },
        {
             "type": "button",
             "content": "Mentörle Tanış ⚡",
             "action": { "type": "SAVE_PROFILE", "target": "chat" },
             "style": { "backgroundColor": "$BUTTON_BG$", "padding": 24, "borderRadius": 16, "alignItems": "center", "marginBottom": 15 },
             "textStyle": { "color": "#fff", "fontSize": 24, "fontWeight": "bold" }
        },
        {
             "type": "button",
             "content": "⬅ Ana Ekrana Dön",
             "action": { "type": "NAVIGATE", "target": "home" },
             "style": { "backgroundColor": "transparent", "padding": 15, "borderRadius": 16, "borderWidth": 2, "borderColor": "$BORDER$", "alignItems": "center" },
             "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 16 }
        }
      ]
    },
    "chat": {
      "title": "Mentör Sohbet",
      "style": { "backgroundColor": "$BG$" },
      "elements": [
        {
          "type": "container",
          "style": { "flexDirection": "row", "alignItems": "center", "justifyContent": "space-between", "paddingBottom": 15, "borderBottomWidth": 2, "borderColor": "$BORDER$", "marginBottom": 15 },
          "children": [
            { "type": "button", "content": "⬅", "action": { "type": "NAVIGATE", "target": "profile" }, "style": { "padding": 10, "backgroundColor": "$CARD_BG$", "borderRadius": 10 }, "textStyle": { "color": "$TEXT$" } },
            { "type": "text", "content": "$MENTOR_TYPE_TEXT$", "style": { "fontSize": 22, "fontWeight": "900", "color": "$TEXT$" } },
            { "type": "text", "content": "$MENTOR_AVATAR$", "style": { "fontSize": 28 } }
          ]
        },
        {
          "type": "text",
          "content": "Karakter Değiştir:",
          "style": { "fontSize": 12, "fontWeight": "bold", "color": "$TEXT_MUTED$", "marginBottom": 10 }
        },
        {
          "type": "container",
          "style": { "flexDirection": "row", "justifyContent": "space-between", "marginBottom": 20 },
          "children": [
            { "type": "button", "content": "🥳 Eğlenceli", "action": { "type": "SET_PERSONA", "value": "fun" }, "style": { "backgroundColor": "$CHIP_BG$", "padding": 10, "borderRadius": 12, "borderWidth": 1, "borderColor": "$BORDER$" }, "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 14 } },
            { "type": "button", "content": "😎 Rahat", "action": { "type": "SET_PERSONA", "value": "relaxed" }, "style": { "backgroundColor": "$CHIP_BG$", "padding": 10, "borderRadius": 12, "borderWidth": 1, "borderColor": "$BORDER$" }, "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 14 } },
            { "type": "button", "content": "🎓 Akademik", "action": { "type": "SET_PERSONA", "value": "academic" }, "style": { "backgroundColor": "$CHIP_BG$", "padding": 10, "borderRadius": 12, "borderWidth": 1, "borderColor": "$BORDER$" }, "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 14 } }
          ]
        },
        {
          "id": "chatHistory",
          "type": "container",
          "style": { "flexGrow": 1, "minHeight": 300, "marginBottom": 20, "backgroundColor": "$INPUT_BG$", "borderRadius": 24, "padding": 15, "borderWidth": 1, "borderColor": "$BORDER$" },
          "children": [] 
        },
        {
          "type": "container",
          "style": { "flexDirection": "row", "alignItems": "center" },
          "children": [
            { "type": "textInput", "id": "chat_input", "placeholder": "Mentöre sor...", "style": { "flex": 1, "backgroundColor": "$CARD_BG$", "height": 60, "borderRadius": 30, "paddingHorizontal": 20, "fontSize": 16, "borderWidth": 2, "borderColor": "$BORDER$", "color": "$TEXT$", "marginRight": 10 } },
            { "type": "button", "content": "➤", "action": { "type": "SEND_MESSAGE" }, "style": { "backgroundColor": "$BUTTON_BG$", "width": 60, "height": 60, "borderRadius": 30, "alignItems": "center", "justifyContent": "center" }, "textStyle": { "color": "#fff", "fontSize": 24, "fontWeight": "bold", "marginTop": -5 } }
          ]
        }
      ]
    },
    "cv_form": {
      "title": "CV Oluşturma Formu",
      "style": { "backgroundColor": "$BG$" },
      "elements": [
        { "type": "text", "content": "ATS Europass Uyumlu CV Tasarla", "style": { "fontSize": 32, "fontWeight": "900", "color": "$TEXT$", "marginBottom": 10, "textAlign": "center" } },
        { "type": "text", "content": "1. Adınız Soyadınız nedir?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_name", "placeholder": "Örn: Ahmet Yılmaz", "style": { "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "2. Telefon numaranız ve profesyonel e-posta adresiniz?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_contact", "placeholder": "Örn: 0555... / email@mail.com", "style": { "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "3. Yaşadığınız Şehir?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_city", "placeholder": "Sadece il yeterli (Örn: İstanbul)", "style": { "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "4. En son okul, bölüm, yıl (Mezunsanız Not Ort.)?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_edu", "placeholder": "Eğitim bilgilerinizi listeleyin", "multiline": true, "style": { "minHeight": 60, "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "5. Daha önce nerelerde çalıştınız? Ne yaptınız?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_exp", "placeholder": "Şirket adı, Unvan, Tarihler ve Sorumluluklarınız", "multiline": true, "style": { "minHeight": 80, "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "6. Gurur duyduğunuz başarılarınız? (Mümkünse sayı ile)", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_achievements", "placeholder": "Örn: Satışları %25 artırdım, X projesini tamamladım", "multiline": true, "style": { "minHeight": 60, "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "7. Hangi programları, araçları, dilleri biliyorsunuz?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_skills", "placeholder": "Bilgisayar, ofis programları, yabancı dil vs.", "multiline": true, "style": { "minHeight": 60, "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "8. Başvurduğunuz iş için 3-4 güçlü yönünüz?", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_strengths", "placeholder": "Profesyonel Özet kısmı için", "multiline": true, "style": { "minHeight": 60, "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 15 } },

        { "type": "text", "content": "9. Bonus (Sertifika, Staj, Referans vs.)", "style": { "fontSize": 16, "fontWeight": "bold", "color": "$TEXT$", "marginBottom": 5 } },
        { "type": "textInput", "id": "cv_bonus", "placeholder": "Varsa eklemek istedikleriniz", "multiline": true, "style": { "minHeight": 60, "backgroundColor": "$INPUT_BG$", "borderRadius": 12, "padding": 15, "fontSize": 16, "borderWidth": 1, "borderColor": "$BORDER$", "color": "$TEXT$", "marginBottom": 25 } },

        {
          "type": "button",
          "content": "🚀 Yapay Zeka ile CV'mi Üret! (Beklemesi uzun sürebilir)",
          "action": { "type": "GENERATE_CV_ACTION" },
          "style": { "backgroundColor": "$BUTTON_BG$", "padding": 24, "borderRadius": 16, "alignItems": "center", "marginBottom": 15 },
          "textStyle": { "color": "#fff", "fontSize": 18, "fontWeight": "bold" }
        },
        {
           "type": "button",
           "content": "⬅ Ana Ekrana Dön",
           "action": { "type": "NAVIGATE", "target": "home" },
           "style": { "backgroundColor": "transparent", "padding": 15, "borderRadius": 16, "borderWidth": 2, "borderColor": "$BORDER$", "alignItems": "center", "marginBottom": 40 },
           "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 16 }
        }
      ]
    },
    "cv_result": {
      "title": "Üretilen CV",
      "style": { "backgroundColor": "$BG$" },
      "elements": [
        { "type": "text", "content": "🎓 CV'niz Hazır!", "style": { "fontSize": 32, "fontWeight": "900", "color": "$TEXT$", "marginTop": 10, "marginBottom": 15, "textAlign": "center" } },
        { "type": "button", "content": "⬅ Düzenle / Başa Dön", "action": { "type": "NAVIGATE", "target": "home" }, "style": { "backgroundColor": "$CHIP_BG$", "padding": 15, "borderRadius": 16, "alignItems": "center", "marginBottom": 20 }, "textStyle": { "color": "$TEXT$", "fontWeight": "bold", "fontSize": 16 } },
        {
          "type": "container",
          "style": { "backgroundColor": "$CARD_BG$", "borderRadius": 24, "padding": 20, "borderWidth": 2, "borderColor": "$BORDER$", "marginBottom": 40 },
          "children": [
            { "type": "text", "content": "$EUROPASS_CV_TEXT$", "style": { "fontSize": 14, "color": "$TEXT$", "lineHeight": 22 } }
          ]
        }
      ]
    },
    "jobs": {
      "title": "Sana Özel İlanlar",
      "style": { "backgroundColor": "$BG$" },
      "elements": [
        { "type": "text", "content": "İlanların yükleniyor lütfen bekle...", "style": { "fontSize": 20, "fontWeight": "bold", "color": "$TEXT$", "textAlign": "center", "marginTop": 50 } }
      ]
    }
  }
}
