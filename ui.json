      "$PRIMARY_TXT$": "#362459",
      "$BUTTON_BG$": "#ff8fa3",
      "$INPUT_BG$": "#fcf6b9",
      "$CHIP_BG$": "#bdefbe",
      "$CHAT_BUBBLE_USER$": "#d6beff",
